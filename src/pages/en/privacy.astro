---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import PrivacyPage from "../../components/PrivacyPage.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n";

const locale = "en";
const title = t(locale, "privacy.pageTitle");
const description = t(locale, "privacy.pageDesc");
---

<BaseLayout locale={locale} title={title} description={description}>
  <Navbar locale={locale} />
  <PrivacyPage locale={locale} />
  <Footer locale={locale} />
</BaseLayout>
