---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import SobrePage from "../../components/SobrePage.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n";

const locale = "en";
const title = t(locale, "sobre.pageTitle");
const description = t(locale, "sobre.pageDesc");
---

<BaseLayout locale={locale} title={title} description={description}>
  <Navbar locale={locale} />
  <SobrePage locale={locale} />
  <Footer locale={locale} />
</BaseLayout>
