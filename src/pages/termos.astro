---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import TermosPage from "../components/TermosPage.astro";
import Footer from "../components/Footer.astro";
import { t } from "../i18n";

const locale = "pt-BR";
const title = t(locale, "termos.pageTitle");
const description = t(locale, "termos.pageDesc");
---

<BaseLayout locale={locale} title={title} description={description}>
  <Navbar locale={locale} />
  <TermosPage locale={locale} />
  <Footer locale={locale} />
</BaseLayout>
