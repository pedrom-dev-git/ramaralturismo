---
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt-BR' } = Astro.props;

const links = [
  { label: t(locale, 'nav.home'), href: "#" },
  { label: t(locale, 'nav.destinos'), href: "#destinos" },
  { label: t(locale, 'nav.contato'), href: "#contato" },
];
---

<footer id="contato" class="border-t border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Main grid -->
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8 py-8 md:py-12">
      <!-- Brand -->
      <div class="col-span-12 lg:col-span-4">
        <div class="flex items-center gap-2 mb-4">
          <img src="/logo-amaral.svg" alt="R. Amaral" class="h-8" />
        </div>
        <p class="text-medium-gray text-sm leading-relaxed">
          {t(locale, 'footer.desc')}
        </p>
      </div>

      <!-- Navigation -->
      <div class="col-span-6 md:col-span-3 lg:col-span-2 lg:col-start-7">
        <h4 class="text-sm font-semibold text-dark-gray tracking-wide uppercase mb-3">{t(locale, 'footer.nav')}</h4>
        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-medium-gray hover:text-primary text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-span-6 md:col-span-3 lg:col-span-3">
        <h4 class="text-sm font-semibold text-dark-gray tracking-wide uppercase mb-3">{t(locale, 'footer.contact')}</h4>
        <ul class="space-y-3 text-sm text-medium-gray">
          <li class="flex items-center gap-2">
            <svg aria-hidden="true" class="w-4 h-4 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <a href="tel:+5548999503368" class="hover:text-primary transition-colors">+48 999503368</a>
          </li>
          <li class="flex items-center gap-2">
            <svg aria-hidden="true" class="w-4 h-4 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:contato@ramaral.com.br" class="hover:text-primary transition-colors">contato@ramaral.com.br</a>
          </li>
          <li class="flex items-start gap-2">
            <svg aria-hidden="true" class="w-4 h-4 shrink-0 mt-0.5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span>{t(locale, 'footer.address')}</span>
          </li>
        </ul>

        <!-- Social icons -->
        <div class="flex gap-3 mt-4">
          <a href="#" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-primary/10 flex items-center justify-center text-medium-gray hover:text-primary transition-colors" aria-label="Instagram">
            <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-primary/10 flex items-center justify-center text-medium-gray hover:text-primary transition-colors" aria-label="Facebook">
            <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://wa.me/5548999503368" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-primary/10 flex items-center justify-center text-medium-gray hover:text-primary transition-colors" aria-label="WhatsApp">
            <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.12.553 4.11 1.519 5.838L.057 23.616l5.932-1.556A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818c-1.94 0-3.79-.508-5.417-1.466l-.388-.231-4.025 1.055 1.074-3.922-.253-.402A9.778 9.778 0 012.182 12 9.818 9.818 0 0112 2.182 9.818 9.818 0 0121.818 12 9.818 9.818 0 0112 21.818z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-200 py-6 md:flex md:items-center md:justify-between">
      <p class="text-medium-gray text-sm text-center md:text-left">
        {t(locale, 'footer.copyright')}
      </p>
    </div>
  </div>
</footer>
