---
import type { Locale } from "../i18n";
import { localizedPath, t } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "pt-BR" } = Astro.props;

const homePath = localizedPath(locale, "/");
const mcGallery = [
  "/casos/mc-corporativo-1.webp",
  "/casos/mc-corporativo-2.webp",
  "/casos/mc-corporativo-3.webp",
];
---

<main id="main">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-dark-gray mb-4">
        {t(locale, "casos.heading")}
      </h1>
      <p class="text-lg text-medium-gray max-w-2xl mx-auto">
        {t(locale, "casos.subheading")}
      </p>
    </div>

    <div class="space-y-8">
      <article class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
          {mcGallery.map((src, i) => (
            <img
              src={src}
              alt={`McDonald's — fretamento corporativo ${i + 1}`}
              loading="lazy"
              class="w-full h-48 md:h-64 object-cover"
            />
          ))}
        </div>
        <div class="p-6 md:p-8">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-3">
            {t(locale, "casos.mcdonalds.title")}
          </h2>
          <p class="text-dark-gray leading-relaxed">
            {t(locale, "casos.mcdonalds.body")}
          </p>
        </div>
      </article>

      <article class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
        <img
          src="/casos/apae.webp"
          alt="Grupo da APAE em fretamento social"
          loading="lazy"
          class="w-full h-64 md:h-80 object-cover"
        />
        <div class="p-6 md:p-8">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-3">
            {t(locale, "casos.apae.title")}
          </h2>
          <p class="text-dark-gray leading-relaxed">
            {t(locale, "casos.apae.body")}
          </p>
        </div>
      </article>
    </div>

    <div class="text-center mt-12">
      <a
        href={`${homePath}#hero-form`}
        class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold py-3 px-8 rounded-full transition-colors"
      >
        {t(locale, "casos.cta")}
        <svg
          class="w-4 h-4"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>
</main>
