---
import type { Locale } from "../i18n";
import { localizedPath, t } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "pt-BR" } = Astro.props;

const sectionKeys = [
  "privacy.sections.identification",
  "privacy.sections.dataCollected",
  "privacy.sections.purpose",
  "privacy.sections.legalBasis",
  "privacy.sections.sharing",
  "privacy.sections.rights",
  "privacy.sections.retention",
  "privacy.sections.dpoContact",
] as const;

const contactHref = localizedPath(locale, "/contato-lgpd");
---

<main id="main">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-dark-gray mb-4">
        {t(locale, "privacy.heading")}
      </h1>
    </div>

    <div
      data-draft-banner
      role="note"
      class="bg-yellow-50 border border-yellow-300 text-yellow-900 rounded-lg px-4 py-3 mb-10 text-sm font-medium text-center"
    >
      {t(locale, "privacy.draftBanner")}
    </div>

    <article class="bg-white border border-gray-200 rounded-xl p-6 md:p-8 shadow-sm">
      <h2 class="text-xl md:text-2xl font-bold text-primary mb-4">
        {t(locale, "privacy.sectionsTitle")}
      </h2>
      <ul class="list-disc pl-5 space-y-2 text-dark-gray">
        {sectionKeys.map((k) => <li>{t(locale, k)}</li>)}
      </ul>
      <a
        href={contactHref}
        class="inline-flex items-center gap-1.5 mt-6 text-primary hover:text-primary/80 font-semibold text-sm transition-colors"
      >
        {t(locale, "privacy.contactCta")} →
      </a>
    </article>
  </section>
</main>
