---
const news = [
  { title: "Praia do Rosa", subtitle: "Sul de Santa Catarina", gradient: "from-cyan-600 to-blue-900" },
  { title: "Balneário Camboriú", subtitle: "Litoral catarinense", gradient: "from-blue-500 to-indigo-900" },
  { title: "Serra Gaúcha", subtitle: "Rio Grande do Sul", gradient: "from-emerald-600 to-green-900" },
  { title: "Florianópolis", subtitle: "Ilha da Magia", gradient: "from-teal-500 to-cyan-900" },
  { title: "Bombinhas", subtitle: "Capital do mergulho", gradient: "from-sky-500 to-blue-800" },
];
---

<section id="novidades" class="py-12 md:py-16 lg:py-20 bg-dark scroll-mt-[72px]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="flex items-end justify-between mb-8 md:mb-12">
      <div>
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Destinos</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-white">
          Destinos em Destaque
        </h2>
      </div>
      <div class="flex gap-3">
        <button class="news-prev w-10 h-10 rounded-full border border-white/20 text-white/60 hover:text-white hover:border-white/40 flex items-center justify-center transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button class="news-next w-10 h-10 rounded-full border border-white/20 text-white/60 hover:text-white hover:border-white/40 flex items-center justify-center transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <div class="swiper news-swiper">
      <div class="swiper-wrapper">
        {news.map((item) => (
          <div class="swiper-slide">
            <div class={`relative rounded-xl overflow-hidden h-72 bg-gradient-to-br ${item.gradient} group transition-shadow hover:shadow-2xl`}>
              <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors duration-300"></div>
              <div class="relative h-full flex flex-col justify-end p-6 text-white">
                <h3 class="text-lg font-bold mb-1">{item.title}</h3>
                <p class="text-white/60 text-sm">{item.subtitle}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation } from "swiper/modules";
  import "swiper/css";

  new Swiper(".news-swiper", {
    modules: [Navigation],
    slidesPerView: 1,
    spaceBetween: 20,
    navigation: {
      prevEl: ".news-prev",
      nextEl: ".news-next",
    },
    breakpoints: {
      640: { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>
