---
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt-BR' } = Astro.props;

// Fotos próprias do arquivo da R. Amaral Turismo (operação familiar).
// Hospedadas em public/destinos/ — zero atribuição, zero terceiro, CSP strict.
const news = [
  {
    title: "Beto Carreiro World",
    subtitle: "Parque temático — Penha, SC",
    img: "/destinos/beto-carreiro.webp",
  },
  {
    title: "Paraquedismo em Punta del Este",
    subtitle: "Aventura no Uruguai",
    img: "/destinos/paraquedas-punta-del-este.webp",
  },
  {
    title: "Rafting",
    subtitle: "Aventura em grupo",
    img: "/destinos/rafting.webp",
  },
  {
    title: "Bombinhas",
    subtitle: "Praias e mergulho — SC",
    img: "/destinos/bombinhas.webp",
  },
  {
    title: "Uruguai",
    subtitle: "Excursões internacionais",
    img: "/destinos/uruguai-mansao.webp",
  },
  {
    title: "Resort águas termais",
    subtitle: "Sul de Santa Catarina",
    img: "/destinos/resort-termal.webp",
  },
  {
    title: "Brasília",
    subtitle: "Capital federal",
    img: "/destinos/dono-brasilia.webp",
  },
];
---

<section id="novidades" class="py-12 md:py-16 lg:py-20 bg-dark scroll-mt-[72px]" style="overflow: hidden;">
  <span id="destinos" class="absolute" aria-hidden="true"></span>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="flex items-end justify-between mb-8 md:mb-12">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-white">Destinos</h2>
      </div>
      <div class="flex gap-3">
        <button
          class="news-prev w-10 h-10 rounded-full border border-white/20 text-white/60 hover:text-white hover:border-white/40 flex items-center justify-center transition-colors"
          aria-label={t(locale, 'news.prev')}
        >
          <svg class="w-5 h-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          class="news-next w-10 h-10 rounded-full border border-white/20 text-white/60 hover:text-white hover:border-white/40 flex items-center justify-center transition-colors"
          aria-label={t(locale, 'news.next')}
        >
          <svg class="w-5 h-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <div class="swiper news-swiper" style="overflow: hidden;">
      <div class="swiper-wrapper">
        {news.map((item) => (
          <div class="swiper-slide">
            <figure class="relative rounded-xl overflow-hidden h-72 bg-gray-800 group transition-shadow hover:shadow-2xl m-0">
              <img
                src={item.img}
                alt={`${item.title} — ${item.subtitle}`}
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/0"></div>
              <figcaption class="relative h-full flex flex-col justify-end p-6 text-white">
                <h3 class="text-lg font-bold mb-1">{item.title}</h3>
                <p class="text-white/80 text-sm">{item.subtitle}</p>
              </figcaption>
            </figure>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation } from "swiper/modules";
  import "swiper/css";

  new Swiper(".news-swiper", {
    modules: [Navigation],
    slidesPerView: 1,
    spaceBetween: 20,
    navigation: {
      prevEl: ".news-prev",
      nextEl: ".news-next",
    },
    breakpoints: {
      640: { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>
