---
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt-BR' } = Astro.props;

const partners = ["Cozybnb", "Serendipity", "Hideaway", "Earthly", "The Nook", "Horizon"];
---

<section class="py-12 md:py-16 bg-light-gray scroll-mt-[72px]" style="overflow: hidden;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8">
      <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Parceiros</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tighter">
        {t(locale, 'partners.title')}
      </h2>
    </div>

    <div style="overflow: hidden; width: 100%;">
      <div class="swiper partners-swiper">
        <div class="swiper-wrapper items-center">
          {partners.map((name) => (
            <div class="swiper-slide flex items-center justify-center">
              <span class="text-xl font-semibold text-medium-gray/50 select-none whitespace-nowrap tracking-wide">
                {name}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
</section>

<script>
  import Swiper from "swiper";
  import { Autoplay } from "swiper/modules";
  import "swiper/css";

  new Swiper(".partners-swiper", {
    modules: [Autoplay],
    slidesPerView: 2,
    spaceBetween: 32,
    loop: true,
    autoplay: {
      delay: 2500,
      disableOnInteraction: false,
    },
    breakpoints: {
      480: { slidesPerView: 3 },
      768: { slidesPerView: 4 },
      1024: { slidesPerView: 6 },
    },
  });
</script>
