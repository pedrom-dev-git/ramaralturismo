---
const partners = ["Cozybnb", "Serendipity", "Hideaway", "Earthly", "The Nook", "Horizon"];
---

<section class="py-12 md:py-16 bg-light-gray scroll-mt-[72px]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8">
      <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Parceiros</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tighter">
        Nossos Parceiros
      </h2>
    </div>

    <div class="flex flex-wrap justify-center items-center gap-x-12 sm:gap-x-16 lg:gap-x-24 gap-y-6">
      {partners.map((name) => (
        <span class="text-xl font-semibold text-medium-gray/50 select-none whitespace-nowrap tracking-wide">
          {name}
        </span>
      ))}
    </div>
  </div>
</section>
