---
import ServiceCard from "./ServiceCard.astro";
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt-BR' } = Astro.props;
---

<section id="servicos" class="py-12 md:py-16 lg:py-20 scroll-mt-[72px]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-8 md:mb-12">
      <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">O que fazemos</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tighter mb-4">
        {t(locale, 'services.title')}
      </h2>
      <p class="text-lg text-medium-gray">
        Soluções de transporte para cada necessidade.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <ServiceCard
        title="Transporte Escolar"
        description="Segurança e pontualidade para o dia a dia do seu filho."
        gradient="bg-gradient-to-br from-primary to-blue-800"
        icon='<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>'
      />
      <ServiceCard
        title="Turismo e Viagens"
        description="Conforto e praticidade para viagens em grupo."
        gradient="bg-gradient-to-br from-emerald-600 to-teal-800"
        icon='<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
      />
    </div>

    <div class="text-center mt-10">
      <a
        href="#"
        class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 hover:border-primary text-dark-gray hover:text-primary font-semibold py-3.5 px-8 rounded-full transition duration-150 ease-in-out"
      >
        {t(locale, 'services.seeAll')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
