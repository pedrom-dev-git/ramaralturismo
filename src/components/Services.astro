---
import { localizedPath, t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt-BR' } = Astro.props;
const casosPath = localizedPath(locale, '/casos');

const items = [
  { title: t(locale, 'services.school.title'), desc: t(locale, 'services.school.desc') },
  { title: t(locale, 'services.tourism.title'), desc: t(locale, 'services.tourism.desc') },
  { title: t(locale, 'services.corporate.title'), desc: t(locale, 'services.corporate.desc') },
];
---

<section id="servicos" class="py-16 md:py-20 lg:py-24 scroll-mt-[72px]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start">
      <!-- Left: narrative -->
      <div class="md:pr-4">
        <p class="text-sm text-primary font-bold tracking-widest uppercase mb-4">
          {t(locale, 'services.label')}
        </p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-6 leading-[1.1] text-dark-gray">
          {t(locale, 'services.title')}
        </h2>
        <p class="text-lg text-medium-gray leading-relaxed">
          {t(locale, 'services.narrative')}
        </p>
      </div>

      <!-- Right: compact list -->
      <div class="md:pl-8 md:border-l border-gray-200">
        <ul class="space-y-7 list-none p-0">
          {items.map((item) => (
            <li>
              <h3 class="text-xl md:text-2xl font-bold text-dark-gray mb-1.5">
                {item.title}
              </h3>
              <p class="text-medium-gray leading-relaxed">
                {item.desc}
              </p>
            </li>
          ))}
        </ul>

        <div class="mt-10">
          <a
            href={casosPath}
            class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold py-3 px-7 rounded-full transition-colors group shadow-sm hover:shadow-md"
          >
            {t(locale, 'services.seeAll')}
            <svg
              class="w-4 h-4 transition-transform group-hover:translate-x-1"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
