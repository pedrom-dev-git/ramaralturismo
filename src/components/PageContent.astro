---
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import FleetBanner from './FleetBanner.astro';
import Benefits from './Benefits.astro';
import Services from './Services.astro';
import NewsCarousel from './NewsCarousel.astro';
import Footer from './Footer.astro';
import type { Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt-BR' } = Astro.props;
---

<Navbar locale={locale} />
<main id="main">
  <Hero locale={locale} />
  <FleetBanner locale={locale} />
  <Benefits locale={locale} />
  <Services locale={locale} />
  <NewsCarousel locale={locale} />
</main>
<Footer locale={locale} />
