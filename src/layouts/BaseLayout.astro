---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "R. Amaral — Turismo e Transporte",
  description = "Atendimento personalizado para transporte escolar e viagens em grupo.",
} = Astro.props;

import "../styles/global.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inter font: self-hosted via Fontsource (imported in frontmatter) -->

  </head>
  <body class="font-sans text-dark-gray bg-white">
    <slot />
  </body>
</html>
