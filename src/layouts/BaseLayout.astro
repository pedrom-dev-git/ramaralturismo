---
import type { Locale } from '../i18n';
import { getHtmlLang, t } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const {
  title = "R. Amaral — Turismo e Transporte",
  description = "Atendimento personalizado para transporte escolar e viagens em grupo.",
  locale = 'pt-BR',
} = Astro.props;

const htmlLang = getHtmlLang(locale);
const siteUrl = 'https://ramaral.tur.br';

// og:locale values per locale
const ogLocaleMap: Record<string, string> = {
  'pt-BR': 'pt_BR',
  'en': 'en_US',
  'es': 'es_ES',
};
const ogLocale = ogLocaleMap[locale] ?? 'pt_BR';
const ogAlternates = Object.entries(ogLocaleMap)
  .filter(([l]) => l !== locale)
  .map(([, v]) => v);
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL('/og-cover.jpg', Astro.site).href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "R. Amaral Turismo",
  "legalName": "R. Amaral Transporte e Turismo",
  "taxID": "33.876.985/0001-72",
  "telephone": "+55 48 99950-3368",
  "email": "contato@ramaral.tur.br",
  "url": siteUrl,
  "logo": `${siteUrl}/logo-amaral.svg`,
  "image": `${siteUrl}/og-cover.jpg`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Rua Bromélia, 42",
    "addressLocality": "Tijucas",
    "addressRegion": "SC",
    "postalCode": "88201-516",
    "addressCountry": "BR",
  },
  "areaServed": {
    "@type": "State",
    "name": "Santa Catarina",
  },
  "identifier": [
    {
      "@type": "PropertyValue",
      "propertyID": "ANTT-TAF",
      "value": "006462",
      "description": "Termo de Autorização de Fretamento (TAF) — ANTT, Resolução 4.777/2015",
    },
    {
      "@type": "PropertyValue",
      "propertyID": "SIE-SC-MOBI",
      "value": "2685/c",
      "description": "Sistema Integrado de Egresso SC — transporte intermunicipal",
    },
  ],
  "sameAs": [
    "https://wa.me/5548999503368",
  ],
};

import "../styles/global.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
// Preload hint: resolved by Vite to a hashed asset URL at build time
import interLatin400Url from "@fontsource/inter/files/inter-latin-400-normal.woff2?url";

// Cloudflare Web Analytics — cookieless, LGPD-safe. Token via PUBLIC_CF_ANALYTICS_TOKEN env var.
// If absent (local dev / CI), beacon is omitted entirely — no cookies, no requests.
const cfToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    {ogAlternates.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="pt-BR" href={`${siteUrl}/`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en/`} />
    <link rel="alternate" hreflang="es" href={`${siteUrl}/es/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Inter font: preload hint for latin-400 (most critical subset) -->
    <link rel="preload" href={interLatin400Url} as="font" type="font/woff2" crossorigin />

  </head>
  <body class="font-sans text-dark-gray bg-white">
    <a
      href="#main"
      class="sr-only focus:not-sr-only absolute top-2 left-2 bg-primary text-white p-2 rounded z-50 focus:outline-none"
    >
      {t(locale, 'a11y.skipLink')}
    </a>
    <slot />
    {cfToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cfToken })}
      ></script>
    )}
  </body>
</html>
